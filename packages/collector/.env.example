# Claude (Anthropic)
# Admin API key (sk-ant-admin-...) for organization usage report,
# or standard API key (sk-ant-api-...) for rate-limit header parsing.
CLAUDE_API_KEY=sk-ant-api-your-key-here

# xAI Management API
XAI_API_KEY=xai-your-management-api-key-here
XAI_TEAM_ID=your-team-id-here

# Codex (ChatGPT Business)
# No API key needed — auth token is read from ~/.codex/auth.json automatically.
# Override the auth.json location if needed:
# CODEX_HOME=/custom/path/to/codex

# Polling interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000
